/*
 * Test profile – runs against the bundled example data.
 * Activate with:  nextflow run main.nf -profile test,conda
 */

params {
    genome_folder  = "${projectDir}/example/genomes"
    fastq_folder   = "${projectDir}/example/fastqs/paired"
    read_type      = 'paired'
    outdir         = 'test_results'
    parsnp_flags   = '-c'
    window_size    = 500
    window_overlap = 0
    filter_off     = false
    bootstrap      = false
}

process {
    withLabel: 'process_high' {
        cpus   = 8
        memory = '8.GB'
        time   = '4.h'
    }
    withLabel: 'process_medium' {
        cpus   = 4
        memory = '4.GB'
        time   = '2.h'
    }
    withLabel: 'process_single' {
        cpus   = 1
        memory = '2.GB'
        time   = '1.h'
    }
}

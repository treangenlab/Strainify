/*
 * Strainify – Nextflow configuration
 * Compatible with Nextflow v26 (strict / v2 syntax parser)
 */

// ---------------------------------------------------------------------------
// Pipeline parameters
// ---------------------------------------------------------------------------
params {
    // Required inputs
    genome_folder            = null
    fastq_folder             = null

    // Output
    outdir                   = 'results'

    // Read type
    read_type                = 'paired'      // 'paired' | 'single'

    // Parsnp
    parsnp_flags             = '-c'

    // Variant filtering
    window_size              = 500
    window_overlap           = 0

    // Abundance estimation
    weight_by_entropy        = false
    filter_off               = false
    bootstrap                = false
    bootstrap_iterations     = 100

    // Precomputed variants mode
    use_precomputed_variants = false
    precomputed_dir          = null

    // Optional genome prefiltering step
    prefilter                = false

    // Resource caps
    max_cpus   = Runtime.runtime.availableProcessors()
    max_memory = '128.GB'
    max_time   = '240.h'
}

// ---------------------------------------------------------------------------
// Default process resources (can be overridden by profiles)
// ---------------------------------------------------------------------------
process {
    withLabel: 'process_single' {
        cpus   = 1
        memory = '4.GB'
        time   = '4.h'
    }

    withLabel: 'process_medium' {
        cpus   = 4
        memory = '16.GB'
        time   = '8.h'
    }

    withLabel: 'process_high' {
        cpus   = { [12, params.max_cpus as int].min() }
        memory = '32.GB'
        time   = '24.h'
    }
}

// ---------------------------------------------------------------------------
// Profile definitions
// ---------------------------------------------------------------------------
profiles {
    standard {
        process.executor = 'local'
    }

    conda {
        conda.enabled    = true
        conda.useMamba   = true
        conda.cacheDir   = "${System.getenv('HOME')}/.nextflow/conda"
        process.conda    = "${projectDir}/environment.yml"
        // Force osx-64 builds on Apple Silicon so bioconda packages
        // that lack native arm64 builds are resolved via Rosetta.
        env.CONDA_SUBDIR = 'osx-64'
    }

    test {
        includeConfig 'conf/test.config'
    }
}

// ---------------------------------------------------------------------------
// Nextflow execution reports
// ---------------------------------------------------------------------------
timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/timeline.html"
    overwrite  = true
}
report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/report.html"
    overwrite  = true
}
trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/trace.txt"
    overwrite  = true
}

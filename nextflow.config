/*
 * Strainify – Nextflow configuration
 * Compatible with Nextflow v26 (strict / v2 syntax parser)
 */

// ---------------------------------------------------------------------------
// Pipeline parameters
// ---------------------------------------------------------------------------
params {
    // Required inputs
    genome_folder            = null
    fastq_folder             = null

    // Output
    outdir                   = 'results'

    // Read type
    read_type                = 'paired'      // 'paired' | 'single'

    // Parsnp
    parsnp_flags             = '-c'

    // Variant filtering
    window_size              = 500
    window_overlap           = 0

    // Abundance estimation
    weight_by_entropy        = false
    filter_off               = false
    bootstrap                = false
    bootstrap_iterations     = 100

    // Precomputed variants mode
    use_precomputed_variants = false
    precomputed_dir          = null

    // Optional genome prefiltering step
    prefilter                = false

    // Single-set inputs (filter-run --fastq1 mode; null when using --fastq_folder)
    fastq1                   = null
    fastq2                   = null
    sample_id                = null

    // MAGNET prefilter (filter-run mode). Defaults below match the standalone
    // driver script; null means "fall back to the process default":
    //   magnet_ref_dir null -> <launchDir>/magnet_shared_reference
    //   magnet_cmd     null -> in-repo "python3 ${projectDir}/bin/magnet/magnet.py"
    //   magnet_threads null -> task.cpus
    magnet_ref_dir            = null
    magnet_cmd                = null
    magnet_mode               = 'illumina'
    magnet_threads            = null
    magnet_min_covscore       = 0.5
    magnet_min_breadth        = 0.005
    magnet_min_reads          = 0
    magnet_rescue_min_reads   = 100
    magnet_rescue_min_ani     = 0.97
    // Extras the driver does NOT pass; off unless explicitly set:
    magnet_rescue_min_breadth = null
    magnet_min_mapq           = null
    magnet_extra              = null

    // Resource caps
    max_cpus   = Runtime.runtime.availableProcessors()
    max_memory = '128.GB'
    max_time   = '240.h'
}

// ---------------------------------------------------------------------------
// Show task stdout (your scripts' print() output) live in the terminal
// ---------------------------------------------------------------------------
env {
    // Python buffers stdout when it is not a TTY, so print() would only appear
    // when each task ends. This flushes it immediately.
    PYTHONUNBUFFERED = '1'
}

// ---------------------------------------------------------------------------
// Default process resources
// ---------------------------------------------------------------------------
process {
    // Echo each task's stdout to the terminal (your scripts' print() messages).
    // Scope it to specific steps instead (e.g. `withName: FILTER_VARIANTS { debug = true }`)
    // if the global output is too noisy.
    debug = true

    withLabel: 'process_single' {
        cpus   = 1
        memory = '4.GB'
        time   = '4.h'
    }

    withLabel: 'process_medium' {
        cpus   = 4
        memory = '16.GB'
        time   = '8.h'
    }

    withLabel: 'process_high' {
        cpus   = { [12, params.max_cpus as int].min() }
        memory = '32.GB'
        time   = '24.h'
    }
}

// ---------------------------------------------------------------------------
// Profile definitions
// ---------------------------------------------------------------------------
profiles {
    /*
     * Default profile (applied automatically when no -profile is given).
     *
     * Strainify runs the tools that are already on PATH, so build the
     * environment ONCE from environment.yml and activate it before running:
     *
     *   conda env create -f environment.yml      # one time
     *   conda activate strainify
     *   ./strainify run --genome_folder ... --fastq_folder ...
     *
     * (On Apple Silicon, if a package lacks an osx-arm64 build, create the env
     * under Rosetta instead:  CONDA_SUBDIR=osx-64 conda env create -f environment.yml)
     */
    standard {
        process.executor = 'local'
    }

    /*
     * Test profile: sets the example inputs and small resource caps from
     * conf/test.config. Run from your activated environment:
     *
     *   nextflow run main.nf -profile test
     */
    test {
        includeConfig 'conf/test.config'
    }
}

// ---------------------------------------------------------------------------
// Nextflow execution reports
// ---------------------------------------------------------------------------
timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}

report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/trace.txt"
    overwrite = true
}

// ---------------------------------------------------------------------------
// Completion / error handlers
// Defined here (not in main.nf): config-level handlers run with `workflow` and
// `params` in scope, so they don't hit the "Failed to invoke onComplete" error
// that the in-script version triggered under the strict v26 runtime.
// ---------------------------------------------------------------------------
workflow.onComplete = {
    println "Strainify ${workflow.success ? 'completed successfully' : 'failed'}. Results in: ${params.outdir}"
}

workflow.onError = {
    println "Strainify stopped with an error: ${workflow.errorMessage}"
}
#!/usr/bin/env bash
# strainify – Nextflow launcher for Strainify

set -euo pipefail

# Resolve the directory that contains THIS script, following symlinks.
_SELF="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")")" && pwd)"

# Locate the pipeline directory.
if [[ -n "${STRAINIFY_PIPELINE_DIR:-}" ]]; then
    PIPELINE_DIR="$STRAINIFY_PIPELINE_DIR"
elif [[ -f "$_SELF/main.nf" ]]; then
    # git-clone / developer checkout: script lives next to main.nf
    PIPELINE_DIR="$_SELF"
elif [[ -f "$_SELF/../share/strainify/main.nf" ]]; then
    # conda-installed: bin/ is a sibling of share/
    PIPELINE_DIR="$(cd "$_SELF/../share/strainify" && pwd)"
else
    echo "ERROR: Cannot find main.nf. Set STRAINIFY_PIPELINE_DIR or reinstall Strainify." >&2
    exit 1
fi

# Resolve the Strainify version: explicit env override, else the VERSION file in
# the pipeline dir, else `git describe` for a dev checkout, else 'unknown'.
_strainify_version() {
    if [[ -n "${STRAINIFY_VERSION:-}" ]]; then
        printf '%s\n' "$STRAINIFY_VERSION"
    elif [[ -f "$PIPELINE_DIR/VERSION" ]]; then
        local v=""; IFS= read -r v < "$PIPELINE_DIR/VERSION" || true
        printf '%s\n' "$v"
    elif command -v git >/dev/null 2>&1 && git -C "$PIPELINE_DIR" rev-parse --git-dir >/dev/null 2>&1; then
        git -C "$PIPELINE_DIR" describe --tags --always --dirty 2>/dev/null || echo unknown
    else
        echo unknown
    fi
}

usage() {
    cat <<EOF
Strainify $(_strainify_version)

Usage:
  strainify [run] [nextflow options] --genome_folder <dir> --fastq_folder <dir> [params...]
                                                  # strainify only (no prefiltering)
  strainify filter-run [params...]                # MAGNET prefilter + strainify
  strainify version | -v | --version
  strainify help    | -h | --help

Two modes:
  run         Strainify only. 'run' is optional -- bare args go here too.
  filter-run  MAGNET genome prefiltering, then strainify on the genomes that
              passed. Auto-detects from your input:
                 --fastq_folder DIR  -> every set in the folder (shared index)
                 --fastq1 FILE       -> a single set

Any argument not listed above is passed directly to 'nextflow run'.

Common params:
  --genome_folder   DIR   Reference genomes (.fna / .fa / .fasta[.gz])
  --fastq_folder    DIR   FASTQ files
  --outdir          DIR   Output directory (default: results)
  --read_type       STR   paired (default) or single
  -profile          STR   standard (default), test
                          (build/activate the env from environment.yml first;
                           tools run from your active environment)

filter-run params (MAGNET):
  --magnet_ref_dir  DIR   Persistent shared reference panel + build-once bwa index,
                          reused across all sets. Optional: defaults to
                          <launch_dir>/magnet_shared_reference. Set it to choose the
                          location (recommended for distributed/cluster filesystems).
  --jobs            N     Folder mode: number of sets to process concurrently
                          (default 1 = serial). Each set's heavy steps cap at
                          ~min(12,max_cpus) cores, so set N near (cores / 12) to
                          fill a big node without oversubscribing.
  Single set only:
  --fastq1          FILE  R1 (or the single-end fastq)
  --fastq2          FILE  R2 (omit for single-end)
  --sample_id       STR   Sample name (default: derived from --fastq1)

Examples:
  # Strainify only (paired-end)
  strainify --genome_folder genomes/ --fastq_folder fastqs/

  # Strainify only, with precomputed variants
  strainify run --genome_folder genomes/ --fastq_folder fastqs/ \\
            --use_precomputed_variants --precomputed_dir prev_results/

  # Prefilter + strainify over a WHOLE FOLDER of fastq sets (4 in parallel):
  strainify filter-run --genome_folder genomes/ --fastq_folder fastqs/ \\
            --magnet_ref_dir shared_panel/ --outdir results/ --jobs 4 \\
            [--read_type single]

  # Prefilter + strainify for a SINGLE set (via --fastq1):
  strainify filter-run --genome_folder genomes/ --magnet_ref_dir shared_panel/ \\
            --fastq1 s1_R1.fq.gz --fastq2 s1_R2.fq.gz --sample_id s1
EOF
    exit 0
}

# --- filter-run handlers (single set vs folder of sets, auto-selected) ---

_filter_single() {
    # ONE fastq set: thin passthrough to 'nextflow run main.nf --prefilter'.
    exec "$NXF" run "$PIPELINE_DIR/main.nf" --prefilter "$@"
}

_filter_batch() {
    # A FOLDER of sets: run 'nextflow run main.nf --prefilter' once per set, all
    # sharing the SAME build-once --magnet_ref_dir index. The index is built by
    # whichever set reaches it first and reused unchanged by the rest; the build
    # is marker+lock guarded inside MAGNET, so concurrent sets are safe.
    #
    # --jobs N controls how many sets run at once (default 1 = serial, streamed
    # to the terminal -- unchanged behavior). With N>1, sets run in the
    # background, each with its own work dir and Nextflow log, and each set's
    # console output is captured to <outdir>/<sample>/filter-run.log. Each set's
    # heavy steps cap at ~min(12,max_cpus) cores, so set N near (cores / 12) to
    # fill a big node without oversubscribing.
    #
    # Consume the folder-level params; everything else -- and anything after a
    # literal '--' -- is forwarded verbatim to each per-set 'nextflow run'.
    local GENOME_FOLDER="" FASTQ_FOLDER="" MAGNET_REF_DIR=""
    local OUTDIR="results" READ_TYPE="paired" JOBS=1
    local EXTRA=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --genome_folder)  GENOME_FOLDER="$2";  shift 2;;
            --fastq_folder)   FASTQ_FOLDER="$2";   shift 2;;
            --magnet_ref_dir) MAGNET_REF_DIR="$2"; shift 2;;
            --outdir)         OUTDIR="$2";         shift 2;;
            --read_type)      READ_TYPE="$2";      shift 2;;
            --jobs)           JOBS="$2";           shift 2;;
            --)               shift; EXTRA+=("$@"); break;;
            *)                EXTRA+=("$1"); shift;;
        esac
    done

    [[ -n "$GENOME_FOLDER" ]] || { echo "ERROR: filter-run (folder mode) needs --genome_folder <dir>" >&2; exit 2; }
    [[ -n "$FASTQ_FOLDER"  ]] || { echo "ERROR: filter-run (folder mode) needs --fastq_folder <dir>"  >&2; exit 2; }
    case "$JOBS" in ''|*[!0-9]*) echo "ERROR: --jobs must be a positive integer (got '$JOBS')" >&2; exit 2;; esac
    [[ "$JOBS" -ge 1 ]] || JOBS=1

    mkdir -p "$OUTDIR"
    [[ -n "$MAGNET_REF_DIR" ]] && mkdir -p "$MAGNET_REF_DIR"

    # One set -> one 'nextflow run main.nf --prefilter'. Isolated work dir + log
    # per set so concurrent runs never collide. Sees this function's locals
    # (GENOME_FOLDER, MAGNET_REF_DIR, OUTDIR, EXTRA) via bash dynamic scope.
    _batch_run_one() {
        local sample="$1" r1="$2" r2="${3:-}"
        mkdir -p "$OUTDIR/$sample"
        local args=(-log "$OUTDIR/$sample/.nextflow.log"
            run "$PIPELINE_DIR/main.nf"
            -work-dir "work/$sample"
            --prefilter
            --genome_folder "$GENOME_FOLDER"
            --sample_id "$sample"
            --fastq1 "$r1"
            --outdir "$OUTDIR/$sample")
        [[ -n "$MAGNET_REF_DIR" ]] && args+=(--magnet_ref_dir "$MAGNET_REF_DIR")
        [[ -n "$r2" ]] && args+=(--fastq2 "$r2")
        [[ ${#EXTRA[@]} -gt 0 ]] && args+=("${EXTRA[@]}")
        # Disable Nextflow's ANSI live display when this run's stdout isn't a
        # terminal -- parallel mode redirects it to filter-run.log, and the whole
        # launcher may be redirected too. Otherwise the progress table is redrawn
        # via cursor-up/erase codes every refresh and the redraws stack up in the
        # file (the same RUN_PARSNP row printed dozens of times). Use the env var
        # (-ansi-log is a `run` option whose position is easy to get wrong); a
        # user-supplied -ansi-log flag still overrides it, so skip when they set one.
        local _set_ansi=0 _e
        if ! [ -t 1 ]; then
            _set_ansi=1
            for _e in ${EXTRA[@]+"${EXTRA[@]}"}; do
                [[ "$_e" == "-ansi-log" ]] && _set_ansi=0
            done
        fi
        if [[ "$_set_ansi" -eq 1 ]]; then
            NXF_ANSI_LOG=false "$NXF" "${args[@]}"
        else
            "$NXF" "${args[@]}"
        fi
    }

    # ---- collect the sets (same globbing/validation as before) ----
    local found=0 r1 r2 sample
    local S_NAME=() S_R1=() S_R2=()
    shopt -s nullglob
    if [[ "$READ_TYPE" == "paired" ]]; then
        # Match *_R1/_R2 and *_r1/_r2, .fq / .fastq, optionally .gz.
        for r1 in "$FASTQ_FOLDER"/*_[rR]1.f*q "$FASTQ_FOLDER"/*_[rR]1.f*q.gz; do
            [[ -e "$r1" ]] || continue
            r2="${r1/_R1./_R2.}"; r2="${r2/_r1./_r2.}"
            if [[ ! -e "$r2" ]]; then
                echo "WARN: no mate found for $r1 (expected $r2); skipping" >&2
                continue
            fi
            sample="$(basename "$r1")"; sample="${sample%%_[rR]1.*}"
            S_NAME+=("$sample"); S_R1+=("$r1"); S_R2+=("$r2"); found=$((found+1))
        done
        [[ "$found" -gt 0 ]] || { echo "No paired fastq sets found in $FASTQ_FOLDER" >&2; exit 1; }
    else
        for r1 in "$FASTQ_FOLDER"/*.f*q "$FASTQ_FOLDER"/*.f*q.gz; do
            [[ -e "$r1" ]] || continue
            # Skip paired-looking files in single mode.
            case "$(basename "$r1")" in *_[rR][12].*) continue;; esac
            sample="$(basename "$r1")"; sample="${sample%.f*q}"; sample="${sample%.f*q.gz}"
            S_NAME+=("$sample"); S_R1+=("$r1"); S_R2+=(""); found=$((found+1))
        done
        [[ "$found" -gt 0 ]] || { echo "No single-end fastq files found in $FASTQ_FOLDER" >&2; exit 1; }
    fi

    # ---- dispatch: serial+streamed if JOBS=1, else concurrent in batches ----
    local ok=0 i j bcount=0
    local failed=()
    local B_PID=() B_NAME=()

    if [[ "$JOBS" -le 1 ]]; then
        echo ">>> Processing $found set(s) serially (use --jobs N to parallelize)."
    else
        echo ">>> Processing $found set(s), up to $JOBS at a time. Per-set logs: $OUTDIR/<sample>/filter-run.log"
    fi

    # Shared MAGNET index notice. The index is built ONCE (lock-serialized) by the
    # first set to reach it; the rest wait, then reuse it. Surface that so a cold
    # start -- especially with --jobs > 1 -- doesn't look like it stalled.
    # magnet_ref_dir defaults to <launch_dir>/magnet_shared_reference when unset;
    # build_shared_reference writes .shared_reference_complete last, so its presence
    # means the merged reference and (for illumina) its bwa index are ready.
    local EFF_REF="${MAGNET_REF_DIR:-magnet_shared_reference}"
    if [[ -f "$EFF_REF/.shared_reference_complete" ]]; then
        echo ">>> Reusing existing shared MAGNET index in '$EFF_REF'."
    else
        echo ">>> Building shared MAGNET index in '$EFF_REF' (first set builds it once;"
        echo "    other sets wait on the lock, then reuse it)."
    fi

    for ((i=0; i<found; i++)); do
        sample="${S_NAME[$i]}"; r1="${S_R1[$i]}"; r2="${S_R2[$i]}"
        if [[ "$JOBS" -le 1 ]]; then
            echo ">>> [$sample] MAGNET filter + strainify (shared index: ${MAGNET_REF_DIR:-<pipeline default under launch dir>})"
            if _batch_run_one "$sample" "$r1" "$r2"; then
                ok=$((ok+1))
            else
                echo "ERROR: [$sample] failed (exit $?); continuing with remaining sets" >&2
                failed+=("$sample")
            fi
        else
            mkdir -p "$OUTDIR/$sample"   # must exist before the log redirect opens it
            echo ">>> [$sample] launched (parallel)"
            _batch_run_one "$sample" "$r1" "$r2" > "$OUTDIR/$sample/filter-run.log" 2>&1 &
            B_PID[$bcount]="$!"; B_NAME[$bcount]="$sample"; bcount=$((bcount+1))
            if [[ "$bcount" -ge "$JOBS" ]]; then
                for ((j=0; j<bcount; j++)); do
                    if wait "${B_PID[$j]}"; then
                        ok=$((ok+1)); echo ">>> [${B_NAME[$j]}] done"
                    else
                        echo "ERROR: [${B_NAME[$j]}] failed (see $OUTDIR/${B_NAME[$j]}/filter-run.log); continuing" >&2
                        failed+=("${B_NAME[$j]}")
                    fi
                done
                B_PID=(); B_NAME=(); bcount=0
            fi
        fi
    done

    # drain any remaining background sets (final partial batch)
    if [[ "$bcount" -gt 0 ]]; then
        for ((j=0; j<bcount; j++)); do
            if wait "${B_PID[$j]}"; then
                ok=$((ok+1)); echo ">>> [${B_NAME[$j]}] done"
            else
                echo "ERROR: [${B_NAME[$j]}] failed (see $OUTDIR/${B_NAME[$j]}/filter-run.log); continuing" >&2
                failed+=("${B_NAME[$j]}")
            fi
        done
    fi

    if [[ ${#failed[@]} -gt 0 ]]; then
        echo ">>> Done with failures: ${#failed[@]} of $found set(s) failed (${failed[*]}); $ok succeeded." >&2
        echo ">>> Results for successful sets are under: $OUTDIR/<sample>/" >&2
        exit 1
    fi
    echo ">>> All $found set(s) processed successfully. Results under: $OUTDIR/<sample>/"
}

_filter_auto() {
    # Pick the mode from the inputs: --fastq_folder => batch, --fastq1 => single.
    local has_folder="" has_single="" a
    for a in "$@"; do
        case "$a" in
            --fastq_folder) has_folder=1;;
            --fastq1)       has_single=1;;
        esac
    done
    if [[ -n "$has_folder" && -n "$has_single" ]]; then
        echo "ERROR: filter-run: pass either --fastq_folder (whole folder) OR --fastq1 (single set), not both." >&2
        exit 2
    elif [[ -n "$has_folder" ]]; then
        _filter_batch "$@"
    elif [[ -n "$has_single" ]]; then
        _filter_single "$@"
    else
        echo "ERROR: filter-run needs --fastq_folder <dir> (a folder of sets) or --fastq1 <file> [--fastq2 <file>] (a single set)." >&2
        exit 2
    fi
}

NXF="${NEXTFLOW:-nextflow}"

CMD="${1:-}"
case "$CMD" in
    run)
        shift
        exec "$NXF" run "$PIPELINE_DIR/main.nf" "$@"
        ;;
    filter-run)
        # MAGNET prefilter + strainify. Auto-detects: --fastq_folder => every set
        # in the folder (shared build-once index); --fastq1 => a single set.
        shift
        _filter_auto "$@"
        ;;
    version|-v|--version)
        echo "Strainify $(_strainify_version)"
        "$NXF" -version
        exit 0
        ;;
    help|-h|--help)
        usage
        ;;
    -*)
        # Bare nextflow flags / params passed directly (most common invocation)
        exec "$NXF" run "$PIPELINE_DIR/main.nf" "$@"
        ;;
    "")
        usage
        ;;
    *)
        # Anything unrecognised: forward straight to nextflow run
        exec "$NXF" run "$PIPELINE_DIR/main.nf" "$@"
        ;;
esac